{
  "title": "GlobalRemit Dashboard",
  "panels": [
    {
      "type": "graph",
      "title": "Request Rate",
      "targets": [
        {
          "expr": "rate(http_requests_total[1m])"
        }
      ]
    },
    {
      "type": "graph",
      "title": "Error Rate",
      "targets": [
        {
          "expr": "rate(http_requests_total{status=~\"5..\"}[1m])"
        }
      ]
    },
    {
      "type": "graph",
      "title": "Latency (P95)",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[1m]))"
        }
      ]
    }
  ]
}